    {
      "parameters": {
        "operation": "executeQuery",
        "query": "DO $$\nBEGIN\n  -- Execute action based on parsed intent\n  IF '{{ $json.intent }}' = 'create_task' THEN\n    INSERT INTO personal.tasks (title, due_date, status, category)\n    VALUES (\n      '{{ $json.action.title || \"Untitled\" }}',\n      {{ $json.action.due_date ? \"'\" + $json.action.due_date + \"'\" : 'NULL' }},\n      'pending',\n      '{{ $json.action.category || \"personal\" }}'\n    );\n  ELSIF '{{ $json.intent }}' = 'update_task' THEN\n    UPDATE personal.tasks\n    SET status = '{{ $json.action.status || \"done\" }}', updated_at = NOW()\n    WHERE LOWER(title) LIKE '%' || LOWER('{{ $json.action.title || \"\" }}') || '%'\n    AND status = 'pending';\n  END IF;\nEND $$;",
        "options": {}
      },
