    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst currentMessage = $('Telegram Trigger').first().json.message.text;\n\n// Build messages array from history, handling empty results gracefully\nconst messages = [];\n\n// Filter to only valid conversation rows (skip empty/null results from 0-row queries)\nconst history = items\n  .map(item => item.json)\n  .filter(h => h && h.role && h.content);\n\n// Add history in chronological order (DB returns DESC, so reverse)\nhistory.reverse().forEach(h => {\n  messages.push({ role: h.role, content: h.content });\n});\n\n// Always add current user message\nmessages.push({ role: 'user', content: currentMessage });\n\nconst now = new Date().toISOString();\n\nconst body = {\n  model: 'claude-sonnet-4-6',\n  max_tokens: 1000,\n  system: `You are Rosa, a personal assistant for Vlado. You help manage daily tasks, summarize emails and calendar, monitor home network, and handle personal productivity. Today is ${now}. Always respond concisely. When you identify an action (create task, update task, set reminder), return a JSON object with fields: intent, reply, action. For general conversation just return: {\"intent\": \"chat\", \"reply\": \"your response\"}.`,\n  messages: messages\n};\n\nreturn [{ json: { body, telegramId: $('Telegram Trigger').first().json.message.from.id, userMessage: currentMessage } }];"
      },
      "id": "build-claude-request",
      "name": "Build Claude Request",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1200, 700]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "={{ $credentials.anthropicApi.apiKey }}"
            },
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "content-type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json.body) }}",
        "options": {
          "timeout": 60000
        }
      },
      "id": "claude-api-call",
      "name": "Claude API",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1440, 700],
      "onError": "continueErrorOutput",
      "credentials": {
        "httpHeaderAuth": {
          "id": "anthropic-api-key",
          "name": "Anthropic API Key"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst telegramId = $('Build Claude Request').first().json.telegramId;\nconst userMessage = $('Build Claude Request').first().json.userMessage;\n\n// Extract text from Claude response\nlet rawText = '';\nif (response.content && response.content.length > 0) {\n  rawText = response.content[0].text;\n}\n\n// Try to parse as JSON for action detection\nlet parsed = null;\ntry {\n  // Handle cases where response might be wrapped in markdown code blocks\n  const cleaned = rawText.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n  parsed = JSON.parse(cleaned);\n} catch (e) {\n  parsed = { intent: 'chat', reply: rawText };\n}\n\nconst reply = parsed.reply || rawText;\nconst intent = parsed.intent || 'chat';\nconst action = parsed.action || null;\n\nreturn [{\n  json: {\n    text: reply,\n    intent,\n    action,\n    telegramId,\n    userMessage,\n    assistantReply: reply\n  }\n}];"
      },
