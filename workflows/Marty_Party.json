      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT id, title, due_date, category, status\nFROM personal.tasks\nWHERE status = 'pending'\nAND (due_date::date = CURRENT_DATE OR due_date IS NULL)\nORDER BY due_date ASC",
        "options": {}
