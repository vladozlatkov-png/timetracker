      "id": "postgres-daily-tasks",
      "name": "Get Daily Tasks",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [1200, -100],
      "onError": "continueErrorOutput",
      "credentials": {
        "postgres": {
          "id": "postgres-audit-os",
          "name": "AuditOS Postgres"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const tasks = $input.all();\nif (tasks.length === 0 || !tasks[0].json.id) {\n  return [{ json: { text: '*No pending tasks for today!* \\n\\nUse \"add task\" to create one.' } }];\n}\n\nlet msg = '*📋 Today\\'s Tasks:*\\n\\n';\ntasks.forEach((item, i) => {\n  const t = item.json;\n  const due = t.due_date ? new Date(t.due_date).toLocaleString('en-GB', { hour: '2-digit', minute: '2-digit' }) : 'No deadline';\n  const cat = t.category ? ` \\`${t.category}\\`` : '';\n  msg += `${i + 1}. *${t.title}*${cat}\\n   ⏰ ${due}\\n`;\n});\n\nmsg += `\\n_Total: ${tasks.length} task(s)_`;\nreturn [{ json: { text: msg } }];"
      },
      "id": "format-daily-tasks",
      "name": "Format Tasks",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1440, -100]
    },
    {
      "parameters": {
        "jsCode": "const message = $('Telegram Trigger').first().json.message.text;\n\n// Remove the trigger command portion and parse the rest\nconst text = message.replace(/add\\s*task/i, '').trim();\n\n// Try to extract a date pattern (YYYY-MM-DD, DD/MM/YYYY, tomorrow, today)\nlet dueDate = null;\nlet title = text;\n\n// ISO date\nconst isoMatch = text.match(/(\\d{4}-\\d{2}-\\d{2})/);\n// Relative dates\nconst tomorrowMatch = text.match(/\\btomorrow\\b/i);\nconst todayMatch = text.match(/\\btoday\\b/i);\n\nif (isoMatch) {\n  dueDate = isoMatch[1];\n  title = text.replace(isoMatch[0], '').trim();\n} else if (tomorrowMatch) {\n  const d = new Date();\n  d.setDate(d.getDate() + 1);\n  dueDate = d.toISOString().split('T')[0];\n  title = text.replace(/\\btomorrow\\b/i, '').trim();\n} else if (todayMatch) {\n  dueDate = new Date().toISOString().split('T')[0];\n  title = text.replace(/\\btoday\\b/i, '').trim();\n}\n\n// Clean up extra whitespace and trailing punctuation\ntitle = title.replace(/\\s+/g, ' ').replace(/^[\\s,:-]+|[\\s,:-]+$/g, '').trim();\n\nif (!title) {\n  title = 'Untitled task';\n}\n\nreturn [{ json: { title, dueDate } }];"
      },
      "id": "parse-add-task",
      "name": "Parse Add Task",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1200, 60]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO personal.tasks (title, due_date, status, category)\nVALUES (\n  '{{ $json.title }}',\n  {{ $json.dueDate ? \"'\" + $json.dueDate + \"'\" : 'NULL' }},\n  'pending',\n  'personal'\n)\nRETURNING id, title, due_date",
        "options": {}
      },
