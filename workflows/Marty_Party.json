      "id": "postgres-conversation-history",
      "name": "Get Conversation History",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [940, 560],
      "credentials": {
        "postgres": {
          "id": "postgres-audit-os",
          "name": "AuditOS Postgres"
        }
      },
      "settings": {
        "alwaysOutputData": true
      }
