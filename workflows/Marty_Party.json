    {
      "parameters": {
        "jsCode": "const t = $input.first().json;\nconst due = t.due_date ? `\\n📅 Due: ${t.due_date}` : '';\nreturn [{ json: { text: `✅ *Task added!*\\n\\n*${t.title}*${due}\\nStatus: pending` } }];"
      },
      "id": "format-add-task",
      "name": "Confirm Add",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1680, 60]
    },
    {
      "parameters": {
        "jsCode": "const message = $('Telegram Trigger').first().json.message.text;\nconst taskName = message.replace(/complete\\s*task/i, '').replace(/done\\s*with/i, '').trim().replace(/^[\\s,:-]+|[\\s,:-]+$/g, '');\nreturn [{ json: { taskName } }];"
      },
      "id": "parse-complete-task",
      "name": "Parse Complete",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1200, 220]
